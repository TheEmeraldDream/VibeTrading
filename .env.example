# ── AI provider ──────────────────────────────────────────────────────
# The app auto-detects which key is present (priority: Anthropic → OpenAI → Google).
# You only need one. Paste your key after the = sign.
#
# To force a specific provider, uncomment and set AI_PROVIDER:
# AI_PROVIDER=anthropic

# Claude (Anthropic) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# ChatGPT (OpenAI) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Gemini (Google) — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ── Server (optional) ────────────────────────────────────────────────
# Defaults: HOST=127.0.0.1, PORT=8000
# For local network access change HOST to 0.0.0.0
# HOST=127.0.0.1
# PORT=8000

# ── Deployment ───────────────────────────────────────────────────────
# CORS: only needed if your frontend is served from a different domain.
# Leave blank when the frontend is served by this same server (default).
# ALLOWED_ORIGINS=https://yourdomain.com

# Set to "true" to enable /docs (Swagger UI). Off by default.
# DOCS_ENABLED=false
