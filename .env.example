# AI provider — auto-detects from whichever key is present (priority: Anthropic → OpenAI → Google)
# Uncomment to force a specific provider:
# AI_PROVIDER=anthropic

# Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# OpenAI GPT (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Google Gemini (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=
